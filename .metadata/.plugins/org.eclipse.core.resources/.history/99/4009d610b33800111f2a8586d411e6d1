package com.microservices.client.service;

import org.springframework.http.*;
import org.springframework.stereotype.Service;
import org.springframework.util.*;
import org.springframework.web.client.RestTemplate;

import com.microservices.client.model.Employee;

import java.util.Map;

//Added for AES Integration Mayur 15/04/26 
import com.microservices.client.util.AESUtil;

@Service
public class EmployeeService {

    public Employee callServer() {

        RestTemplate restTemplate = new RestTemplate();

        //  STEP 1: Get token (OAuth2 way)
        HttpHeaders tokenHeaders = new HttpHeaders();
        tokenHeaders.setBasicAuth("my-client", "secret"); // IMPORTANT
        tokenHeaders.setContentType(MediaType.APPLICATION_FORM_URLENCODED);

        MultiValueMap<String, String> body = new LinkedMultiValueMap<>();
        body.add("grant_type", "client_credentials");

        HttpEntity<MultiValueMap<String, String>> tokenRequest =
                new HttpEntity<>(body, tokenHeaders);

        Map tokenResponse = restTemplate.postForObject(
                "http://localhost:9000/oauth2/token",
                tokenRequest,
                Map.class
        );

        String token = (String) tokenResponse.get("access_token");

        //  STEP 2: Call resource server
        HttpHeaders headers = new HttpHeaders();
        headers.set("Authorization", "Bearer " + token);

        String plainData = "101";
        String encryptedData = AESUtil.encrypt(plainData);

        headers.setContentType(MediaType.TEXT_PLAIN); // VERY IMPORTANT

        HttpEntity<String> request = new HttpEntity<>(encryptedData, headers);

        ResponseEntity<Employee> response = restTemplate.exchange(
                "http://localhost:8081/api/employee",
                HttpMethod.POST,
                request,
                Employee.class
        );

        return response.getBody();
    }
}