import javax.crypto.Cipher;
import javax.crypto.KeyGenerator;
import javax.crypto.SecretKey;
import java.security.*;
import java.security.spec.X509EncodedKeySpec;
import java.util.Base64;

public class ClientTest {

    public static void main(String[] args) throws Exception {

        // 1. Your JSON
        String json = "{\"id\":\"101\",\"name\":\"John\"}";

        // 2. Generate AES key
        KeyGenerator keyGen = KeyGenerator.getInstance("AES");
        keyGen.init(128);
        SecretKey aesKey = keyGen.generateKey();

        // 3. Encrypt JSON using AES
        Cipher aesCipher = Cipher.getInstance("AES");
        aesCipher.init(Cipher.ENCRYPT_MODE, aesKey);
        byte[] encryptedDataBytes = aesCipher.doFinal(json.getBytes());
        String encryptedData = Base64.getEncoder().encodeToString(encryptedDataBytes);

        // 4. Load PUBLIC KEY (paste your key here)
        String publicKeyStr = "PASTE_YOUR_PUBLIC_KEY_HERE";

        byte[] decodedKey = Base64.getDecoder().decode(publicKeyStr);
        X509EncodedKeySpec keySpec = new X509EncodedKeySpec(decodedKey);
        KeyFactory keyFactory = KeyFactory.getInstance("RSA");
        PublicKey publicKey = keyFactory.generatePublic(keySpec);

        // 5. Encrypt AES key using RSA
        Cipher rsaCipher = Cipher.getInstance("RSA");
        rsaCipher.init(Cipher.ENCRYPT_MODE, publicKey);
        byte[] encryptedKeyBytes = rsaCipher.doFinal(aesKey.getEncoded());
        String encryptedKey = Base64.getEncoder().encodeToString(encryptedKeyBytes);

        // 6. Print results
        System.out.println("DATA = " + encryptedData);
        System.out.println("KEY  = " + encryptedKey);
    }
}